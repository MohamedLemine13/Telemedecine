#!/bin/sh
# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup batch script (script-only variant).
# Downloads Maven on first run using the URL in
# .mvn/wrapper/maven-wrapper.properties (no jar needed).
# Generated by https://maven.apache.org/wrapper/.
# ----------------------------------------------------------------------------
set -euf
[ "${MVNW_VERBOSE-}" != debug ] || set -x

# OS specific support.
native_path() { printf %s\\n "$1"; }
case "$(uname)" in
CYGWIN* | MINGW*)
  [ -z "${JAVA_HOME-}" ] || JAVA_HOME="$(cygpath --unix "$JAVA_HOME")"
  native_path() { cygpath --path --windows "$1"; }
  ;;
esac

# set JAVACMD and JAVACCMD
set_java_home() {
  if [ -z "${JAVA_HOME-}" ]; then
    if [ -x /usr/libexec/java_home ]; then
      JAVA_HOME="$(/usr/libexec/java_home)" || return
    else
      JAVA_HOME="$(dirname "$(dirname "$(readlink -f "$(command -v javac)")")")" || return
    fi
  fi
  JAVACMD="$JAVA_HOME/bin/java"
  JAVACCMD="$JAVA_HOME/bin/javac"
  [ -x "$JAVACMD" ] || { echo "The JAVA_HOME environment variable is not defined correctly: $JAVA_HOME" >&2; return 1; }
  [ -x "$JAVACCMD" ] || { echo "The javac executable does not exist: $JAVACCMD" >&2; return 1; }
}

# hash string like Java String.hashCode()
hash_string() {
  str="${1:-}" h=0
  while [ -n "$str" ]; do
    char="${str%"${str#?}"}"
    h=$(( ( h * 31 + $(LC_CTYPE=C printf %d "'$char") ) % 4294967296 ))
    str="${str#?}"
  done
  printf %x\\n $h
}

verbose() { :; }
[ "${MVNW_VERBOSE-}" != true ] || verbose() { printf %s\\n "${1-}"; }

die() { printf %s\\n "$1" >&2; exit 1; }

trim() { printf "%s" "${1// /}"; }

# parse distributionUrl and optional distributionSha256Sum from .mvn/wrapper/maven-wrapper.properties
while IFS="=" read -r key value; do
  case "${key-}" in
  distributionUrl)      distributionUrl=$(trim "$value") ;;
  distributionSha256Sum) distributionSha256Sum=$(trim "$value") ;;
  esac
done < "${0%/*}/.mvn/wrapper/maven-wrapper.properties"
[ -n "${distributionUrl-}" ] || die "cannot read distributionUrl property in .mvn/wrapper/maven-wrapper.properties"

case "${distributionUrl##*/}" in
maven-mvnd-*bin.*) MVN_CMD=mvnd.sh _MVNW_REPO_PATTERN=/maven/mvnd/ ;;
maven-*bin.*) MVN_CMD="mvn${0##*/mvnw}" _MVNW_REPO_PATTERN=/org/apache/maven/ ;;
*) die "distributionUrl is not valid, must match *-bin.zip, but found '$distributionUrl'" ;;
esac

# Local Maven cache dir
MAVEN_USER_HOME="${MAVEN_USER_HOME:-${HOME}/.m2}"
[ -d "$MAVEN_USER_HOME" ] || mkdir -p "$MAVEN_USER_HOME"
MAVEN_HOME="${MAVEN_USER_HOME}/wrapper/dists/$(echo "$distributionUrl" | tr : / | sed -E 's,^https?/+,,')"
distributionUrlName="${distributionUrl##*/}"
distributionUrlNameMain="${distributionUrlName%.*}"
distributionUrlNameMain="${distributionUrlNameMain%-bin}"
MAVEN_HOME="${MAVEN_HOME%/}/${distributionUrlNameMain}"

exec_maven() {
  unset MVNW_VERBOSE MVNW_USERNAME MVNW_PASSWORD MVNW_REPOURL || :
  exec "$MAVEN_HOME/bin/$MVN_CMD" "$@" || die "cannot exec $MAVEN_HOME/bin/$MVN_CMD"
}

if [ -d "$MAVEN_HOME" ]; then
  verbose "found existing MAVEN_HOME at $MAVEN_HOME"
  exec_maven "$@"
fi

case "${distributionUrl-}" in
*?-bin.zip) ;;
*) die "distributionUrl is not valid, must end with *-bin.zip, but found '$distributionUrl'" ;;
esac

# prepare tmp dir
if TMP_DOWNLOAD_DIR="$(mktemp -d)" && [ -d "$TMP_DOWNLOAD_DIR" ]; then
  clean() { rm -rf -- "$TMP_DOWNLOAD_DIR"; }
  trap clean HUP INT TERM EXIT
else
  die "cannot create temp dir"
fi

mkdir -p -- "${MAVEN_HOME%/*}"

set_java_home

# download and verify Maven distribution
if command -v wget > /dev/null; then
  verbose "Downloading from: $distributionUrl"
  [ "${MVNW_VERBOSE-}" = true ] && QUIET="" || QUIET="--quiet"
  if [ -n "${MVNW_USERNAME-}" ] && [ -n "${MVNW_PASSWORD-}" ]; then
    wget $QUIET --http-user="$MVNW_USERNAME" --http-password="$MVNW_PASSWORD" "$distributionUrl" -O "$TMP_DOWNLOAD_DIR/$distributionUrlName" || die "wget failed"
  else
    wget $QUIET "$distributionUrl" -O "$TMP_DOWNLOAD_DIR/$distributionUrlName" || die "wget failed"
  fi
elif command -v curl > /dev/null; then
  verbose "Downloading from: $distributionUrl"
  [ "${MVNW_VERBOSE-}" = true ] && QUIET="" || QUIET="--silent"
  if [ -n "${MVNW_USERNAME-}" ] && [ -n "${MVNW_PASSWORD-}" ]; then
    curl $QUIET -u "$MVNW_USERNAME:$MVNW_PASSWORD" -o "$TMP_DOWNLOAD_DIR/$distributionUrlName" "$distributionUrl" -f -L || die "curl failed"
  else
    curl $QUIET -o "$TMP_DOWNLOAD_DIR/$distributionUrlName" "$distributionUrl" -f -L || die "curl failed"
  fi
elif set_java_home; then
  verbose "Falling back to Java to download"
  javaSource="$TMP_DOWNLOAD_DIR/Downloader.java"
  targetZip="$TMP_DOWNLOAD_DIR/$distributionUrlName"
  cat > "$javaSource" <<-END
	public class Downloader {
	  public static void main(String[] args) throws Exception {
	    java.nio.file.Files.copy(java.net.URI.create(args[0]).toURL().openStream(),
	      java.nio.file.Path.of(args[1]),
	      java.nio.file.StandardCopyOption.REPLACE_EXISTING);
	  }
	}
END
  "$JAVACCMD" -d "$TMP_DOWNLOAD_DIR" "$javaSource" || die "javac failed"
  "$JAVACMD" -cp "$TMP_DOWNLOAD_DIR" Downloader "$distributionUrl" "$targetZip" || die "java download failed"
fi

verbose "Checking sha256sum"
if [ -n "${distributionSha256Sum-}" ]; then
  if command -v sha256sum > /dev/null; then
    echo "$distributionSha256Sum  $TMP_DOWNLOAD_DIR/$distributionUrlName" | sha256sum -c - > /dev/null || die "sha256 mismatch"
  elif command -v shasum > /dev/null; then
    echo "$distributionSha256Sum  $TMP_DOWNLOAD_DIR/$distributionUrlName" | shasum -a 256 -c - > /dev/null || die "sha256 mismatch"
  fi
fi

verbose "Unpacking"
unzip_dir="$(mktemp -d -p "$TMP_DOWNLOAD_DIR")"
command -v unzip > /dev/null && UNZIP=unzip || UNZIP="jar xf"
$UNZIP "$TMP_DOWNLOAD_DIR/$distributionUrlName" -d "$unzip_dir" || die "unzip failed"

mv -- "$unzip_dir/$distributionUrlNameMain" "$MAVEN_HOME" || die "cannot move $unzip_dir/$distributionUrlNameMain to $MAVEN_HOME"

clean || :
exec_maven "$@"
